{
  "fields": {
    "name": {
      "type": "personName",
      "isRequired": true
    },
    "email": {
      "type": "email"
    },
    "phone": {
      "type": "phone"
    },
    "address": {
      "type": "address"
    },
    "dateOfBirth": {
      "type": "date"
    },
    "ssnLast4": {
      "type": "varchar",
      "maxLength": 4,
      "label": "SSN Last 4"
    },
    "status": {
      "type": "enum",
      "options": ["Lead", "Active", "Paused", "Completed", "Cancelled"],
      "default": "Lead",
      "isRequired": true
    },
    "servicePackage": {
      "type": "enum",
      "options": ["Basic", "Standard", "Premium"],
      "default": "Standard"
    },
    "creditGoal": {
      "type": "text",
      "rowsMin": 2
    },
    "startDate": {
      "type": "date"
    },
    "expectedCompletionDate": {
      "type": "date"
    },
    "monthlyFee": {
      "type": "currency"
    },
    "source": {
      "type": "enum",
      "options": ["", "Referral", "Website", "Social Media", "Advertisement", "Other"]
    },
    "assignedUser": {
      "type": "link",
      "entity": "User"
    },
    "assignedUserName": {
      "type": "varchar",
      "notStorable": true
    },
    "notes": {
      "type": "text"
    },
    "createdAt": {
      "type": "datetime",
      "readOnly": true
    },
    "modifiedAt": {
      "type": "datetime",
      "readOnly": true
    },
    "createdBy": {
      "type": "link",
      "entity": "User",
      "readOnly": true
    },
    "modifiedBy": {
      "type": "link",
      "entity": "User",
      "readOnly": true
    }
  },
  "links": {
    "creditReports": {
      "type": "hasMany",
      "entity": "CreditReport",
      "foreign": "creditClient"
    },
    "disputeRounds": {
      "type": "hasMany",
      "entity": "DisputeRound",
      "foreign": "creditClient"
    },
    "disputeItems": {
      "type": "hasMany",
      "entity": "DisputeItem",
      "foreign": "creditClient"
    },
    "disputeLetters": {
      "type": "hasMany",
      "entity": "DisputeLetter",
      "foreign": "creditClient"
    },
    "paymentPlans": {
      "type": "hasMany",
      "entity": "PaymentPlan",
      "foreign": "creditClient"
    },
    "assignedUser": {
      "type": "belongsTo",
      "entity": "User"
    },
    "createdBy": {
      "type": "belongsTo",
      "entity": "User"
    },
    "modifiedBy": {
      "type": "belongsTo",
      "entity": "User"
    }
  },
  "indexes": {
    "status": {
      "columns": ["status", "deleted"]
    },
    "assignedUser": {
      "columns": ["assignedUserId", "deleted"]
    }
  },
  "collection": {
    "orderBy": "createdAt",
    "order": "desc"
  }
}
